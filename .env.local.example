# Copy this file to .env.local and fill in your values.
# .env.local is excluded from version control — never commit secrets.

# Google Gemini API key (required for OCR, news ranking, and AI tips)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Basic auth credentials — protect the app when hosted
AUTH_USER=admin
AUTH_PASS=change-me-to-a-long-random-password
